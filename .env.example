# Deadbounce app configuration — copy to .env and fill in real values.
# Debug builds use API_BASE_URL_DEV, release builds use API_BASE_URL_PROD
# (selected by kDebugMode in AppConfig).

# 10.0.2.2 is the Android emulator's alias for the host machine. Use your
# LAN IP (e.g. http://192.168.0.42:8394) for a physical device.
API_BASE_URL_DEV=http://10.0.2.2:8394
API_BASE_URL_PROD=https://deadbounce.pranta.dev

# Web (server) OAuth client ID for Google Sign-In — find it in the Firebase
# console (Authentication -> Sign-in method -> Google -> Web SDK configuration)
# or Google Cloud Console -> Credentials.
GOOGLE_SERVER_CLIENT_ID=your-client-id.apps.googleusercontent.com
